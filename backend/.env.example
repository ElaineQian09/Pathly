NODE_ENV=production
PORT=3000

# Railway public URL for the backend service, e.g. https://pathly-backend-production.up.railway.app
PATHLY_BASE_URL=

# Persisted state directory. When using a Railway Volume, mount it here.
PATHLY_DATA_DIR=/app/.pathly-data

# Google Maps Platform
GOOGLE_API_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PLANNER_MODEL=gemini-2.5-flash

# Optional audio host override
PATHLY_AUDIO_BASE_URL=
