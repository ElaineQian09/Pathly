PRODUCT_NAME = Pathly
PRODUCT_BUNDLE_IDENTIFIER = com.pathly.ios
MARKETING_VERSION = 1.0
CURRENT_PROJECT_VERSION = 1
IPHONEOS_DEPLOYMENT_TARGET = 17.0
SWIFT_VERSION = 5.0
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = $(PATHLY_DEVELOPMENT_TEAM)
TARGETED_DEVICE_FAMILY = 1
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_CFBundleDisplayName = Pathly
INFOPLIST_KEY_NSLocationWhenInUseUsageDescription = Pathly uses your location to build routes, keep navigation visible, and send route-aware context snapshots during runs.
INFOPLIST_KEY_NSLocationAlwaysAndWhenInUseUsageDescription = Pathly uses your location to keep navigation visible and guidance accurate during active runs.
INFOPLIST_KEY_NSMicrophoneUsageDescription = Pathly uses the microphone so you can interrupt Maya and Theo with live voice questions.
INFOPLIST_KEY_NSMotionUsageDescription = Pathly uses motion data to track steps, cadence, pace, and pause or resume status.
INFOPLIST_KEY_UIApplicationSupportsIndirectInputEvents = YES
INFOPLIST_KEY_PathlyAPIBaseURL = $(PATHLY_API_BASE_URL)
INFOPLIST_KEY_PathlyUseMocks = $(PATHLY_USE_MOCKS)
INFOPLIST_KEY_PathlyGoogleMapsAPIKey = $(GOOGLE_MAPS_API_KEY)
LD_RUNPATH_SEARCH_PATHS = $(inherited) @executable_path/Frameworks
